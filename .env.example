# agent-notify environment configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# -------------------------------------------------------
# Pushover push notifications (optional)
# Sign up at https://pushover.net to get these values.
# -------------------------------------------------------

# Your Pushover application API token
PUSHOVER_TOKEN=

# Your Pushover user key
PUSHOVER_USER=

# Optional Pushover auto-expire TTLs in seconds.
# Unset uses the defaults below. Set blank to omit ttl entirely.
#   finish    default -> 120
#   attention default -> 900
AGENT_NOTIFY_PUSH_TTL_FINISH=
AGENT_NOTIFY_PUSH_TTL_ATTENTION=

# -------------------------------------------------------
# Backend selection
# -------------------------------------------------------

# Comma-separated list of backends to run.
# Available: sound, pushover
# Default when unset: sound
#
# Examples:
#   AGENT_NOTIFY_BACKENDS=sound
#   AGENT_NOTIFY_BACKENDS=sound,pushover
#   AGENT_NOTIFY_BACKENDS=pushover
AGENT_NOTIFY_BACKENDS=sound

# Optional per-event sound overrides for the sound backend.
# macOS defaults:
#   finish    -> /System/Library/Sounds/Glass.aiff
#   attention -> /System/Library/Sounds/Funk.aiff
AGENT_NOTIFY_SOUND_FINISH=
AGENT_NOTIFY_SOUND_ATTENTION=

# -------------------------------------------------------
# HiveMind quiet-mode integration (optional)
# -------------------------------------------------------

# Base URL of your HiveMind server.
# agent-notify will check GET /api/jarvis/quiet-mode before every outbound
# notification and suppress it when quiet mode is enabled.
# Set to "" (empty) to skip the check silently.
# Default when unset: http://localhost:8000
HIVEMIND_BASE_URL=http://localhost:8000

# Shared secret for HiveMind's X-Jarvis-Api-Secret header.
# Leave empty if HiveMind is running without authentication (local dev default).
HIVEMIND_API_SECRET=

# Set to 0 to disable the quiet-mode check entirely (e.g. in offline envs).
# Default when unset: 1 (check is active)
AGENT_NOTIFY_QUIET_MODE_CHECK=1
